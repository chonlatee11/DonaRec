# Copy to .env.local and fill in real values. .env.local is gitignored — never commit secrets.

# Go API base URL (donnarec-api). Defaults to http://localhost:8000 if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Keycloak OIDC client — donnarec-frontend is a CONFIDENTIAL client (NextAuth runs
# server-side, so it can safely hold a client secret). Get the secret from the
# Keycloak admin console: Clients -> donnarec-frontend -> Credentials.
KEYCLOAK_CLIENT_ID=donnarec-frontend
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=http://localhost:8080/realms/donnarec

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Optional — donation consent text version shown on the public form (has a safe default).
# NEXT_PUBLIC_CONSENT_TEXT_VERSION=1.0
